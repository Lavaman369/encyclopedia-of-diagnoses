			<GameDBLocalizedString>	<LocID>SYM_MOREDG_PROLACTINOME_DESCRIPTION</LocID>						<Text>Discovery of a prolactinoma on MRI.</Text>	</GameDBLocalizedString>
			<GameDBLocalizedString>	<LocID>SYM_MOREDG_ADENOME_SOMATOTROPE</LocID>							<Text>Somatotropic adenoma</Text>	</GameDBLocalizedString>
